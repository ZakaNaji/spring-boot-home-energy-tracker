      "item": [
        {
          "name": "Create User - Success",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John\",\n  \"surname\": \"Doe\",\n  \"email\": \"{{userEmail}}\",\n  \"address\": \"123 Green Street, Fez\",\n  \"alertingEnabled\": true,\n  \"energyAlertThreshold\": 350.5\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const response = pm.response.json();",
                  "pm.collectionVariables.set(\"userId\", response.id);",
                  "pm.collectionVariables.set(\"userEmail\", response.email);",
                  "",
                  "pm.test(\"Response contains created user id\", function () {",
                  "    pm.expect(response.id).to.exist;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "response": []
        },
