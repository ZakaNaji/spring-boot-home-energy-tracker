{
  "info": {
    "_postman_id": "b7fd3f7a-0b25-4d86-9d5c-fc2dd9e6c501",
    "name": "Home Energy Tracker - Simulator Service",
    "description": "Postman collection for simulator-service endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "simulatorServiceBaseUrl",
      "value": "http://localhost:8084"
    },
    {
      "key": "deviceId",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Simulator Service",
      "item": [
        {
          "name": "Run Simulation Once - Success",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{simulatorServiceBaseUrl}}/api/simulation/run-once",
              "host": [
                "{{simulatorServiceBaseUrl}}"
              ],
              "path": [
                "api",
                "simulation",
                "run-once"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const response = pm.response.json();",
                  "",
                  "pm.test(\"Response contains message\", function () {",
                  "    pm.expect(response.message).to.exist;",
                  "});",
                  "",
                  "pm.test(\"Response contains readingsSent\", function () {",
                  "    pm.expect(response.readingsSent).to.be.a('number');",
                  "    pm.expect(response.readingsSent).to.be.greaterThan(0);",
                  "});"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Run Simulation Batch - Success",
